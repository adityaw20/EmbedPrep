{
  "name": "embedprep",
  "version": "1.0.0",
  "description": "Comprehensive Interview Preparation Platform for Embedded Engineers",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "setup": "node setup-credentials.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "seed": "cd backend && npm run seed",
    "seed:real": "cd backend && node utils/addRealQuestions.js",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/EmbedPrep.git"
  },
  "keywords": [
    "embedded-systems",
    "firmware",
    "iot",
    "interview-prep",
    "mcq",
    "nextjs",
    "mongodb"
  ],
  "author": "EmbedPrep Team",
  "license": "MIT"
}
